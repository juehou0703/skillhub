# ── Backend environment variables ──────────────────────────────────────────────
# Copy this to .env for local dev. Railway reads these from its dashboard.

# PostgreSQL connection string
# Railway provides this automatically when you add a Postgres plugin.
DATABASE_URL=postgres://skillhub:skillhub_dev@localhost:5433/skillhub

# Port the Hono server listens on (Railway sets this automatically)
PORT=3000

# Directory where skill SKILL.md files are stored
# In Railway, attach a volume mounted at /app/skills-data
SKILLS_DIR=/app/skills-data

# LLM invocation timeout in milliseconds
LLM_TIMEOUT_MS=60000
