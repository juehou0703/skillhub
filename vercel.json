{
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://skillhub-production-b28a.up.railway.app/api/$1"
    },
    {
      "source": "/mcp(.*)",
      "destination": "https://skillhub-production-b28a.up.railway.app/mcp$1"
    },
    {
      "source": "/.well-known/(.*)",
      "destination": "https://skillhub-production-b28a.up.railway.app/.well-known/$1"
    }
  ]
}
